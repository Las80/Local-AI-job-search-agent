# Local AI Job Search Agent — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# --- Adzuna API (required)
# Get your keys at: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# --- Reed API (required)
# Get your key at: https://www.reed.co.uk/developers
REED_API_KEY=your_reed_api_key

# --- OpenAI API (optional — for web-search job discovery)
# Get your key at: https://platform.openai.com/api-keys
# Uses gpt-4o-search-preview to find UK job listings via web search.
OPENAI_API_KEY=

# --- Telegram (required for notifications)
# Create a bot via @BotFather, then get your chat ID (e.g. from @userinfobot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Scoring and notifications (optional — defaults shown)
# Instant alert when match score >= this value (0.5 = 50%, 1.0 = 100%)
MATCH_THRESHOLD=0.5
# Jobs included in daily digest when score >= this value (0.5 = 50%)
DIGEST_THRESHOLD=0.5
# Seconds to wait before sending another instant alert for the same job
NOTIFICATION_COOLDOWN_SECONDS=3600
# Time for daily digest (24h format)
DIGEST_TIME=08:00

# --- Blacklist (optional)
# Comma-separated company names to filter out from the start
BLACKLISTED_COMPANIES=
